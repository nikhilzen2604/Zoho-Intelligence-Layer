# --- Classifier (DeepSeek) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
CLASSIFIER_MODEL=deepseek-chat
CLASSIFIER_MIN_CONFIDENCE=0.6
DEFAULT_REDIRECT=hello@zenalyst.ai

# --- Zoho Desk (fill in after running zoho_bootstrap.py) ---
ZOHO_DC=in
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
ZOHO_DEPARTMENT_ID=
# agent who reviews enhancement/feature requests (tickets get assigned to them)
ENHANCEMENT_ASSIGNEE_EMAIL=
# support routing: urgent P1/P2 -> high owner, routine P3/P4 -> low owner
SUPPORT_HIGH_ASSIGNEE_EMAIL=
SUPPORT_LOW_ASSIGNEE_EMAIL=

# GitHub backlog: enhancement + incident tickets create an issue here
GITHUB_TOKEN=
GITHUB_REPO=
